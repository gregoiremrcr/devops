server {
    listen {{ nginx_port }} default_server;
    root /var/www/html;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    location /health {
        return 200 '{"status": "ok", "host": "{{ ansible_hostname }}"}';
        add_header Content-Type application/json;
    }
}
